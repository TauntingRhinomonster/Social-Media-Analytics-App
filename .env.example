# Server
PORT=3000
APP_URL=http://localhost:3000

# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Token encryption (32-byte key, base64-encoded)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# OpenAI (for agent + embeddings)
OPENAI_API_KEY=

# Default user for single-tenant dev mode
DEFAULT_USER_ID=
DEFAULT_USER_EMAIL=dev@example.com

# X / Twitter OAuth 2.0
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/oauth/x/callback

# LinkedIn OAuth 2.0
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/oauth/linkedin/callback

# Instagram (Meta Graph API — uses Facebook app credentials)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/oauth/instagram/callback

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
